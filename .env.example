# Domains
VUE_SPRING_DOMAIN=vue-spring.sejongclass.kr
MINIO_DOMAIN=vue-spring-file.sejongclass.kr
RR7_FULLSTACK_DOMAIN=rr7-fullstack.sejongclass.kr

# Images
CADDY_IMAGE=caddy:2-alpine
VUE_IMAGE=ghcr.io/your-org/vue-app:latest
SPRING_IMAGE=ghcr.io/your-org/spring-app:latest
RR7_FULLSTACK_IMAGE=ghcr.io/your-org/rr7-fullstack:latest
MINIO_IMAGE=quay.io/minio/minio:latest

# Internal app ports
VUE_PORT=80
SPRING_PORT=8080
RR7_FULLSTACK_PORT=3000

# MinIO
MINIO_DATA_VOLUME=minio_data
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-minio-password
MINIO_SERVER_URL=https://vue-spring-file.sejongclass.kr
MINIO_REGION=ap-northeast-2
